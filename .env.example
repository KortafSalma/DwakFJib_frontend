# ============================================
# DWAKFJIB FRONTEND - ENVIRONMENT
# ============================================
# Copy to .env and adjust for your environment.

# Backend API URL
# For Docker: use /api (proxied by nginx)
# For local dev: use http://localhost:8000/api
VITE_API_URL=/api

# Demo Mode
# Set to true for demo/presentation, false for production
VITE_DEMO_MODE=false
